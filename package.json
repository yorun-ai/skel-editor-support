{
  "name": "skel-editor-support",
  "version": "0.0.0",
  "private": true,
  "description": "Editor integrations and syntax highlighting for the Skel language.",
  "license": "Apache-2.0",
  "workspaces": [
    "editors/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspace vscode-skel",
    "test:extension": "npm run test:extension --workspace vscode-skel"
  }
}
