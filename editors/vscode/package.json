{
  "name": "vscode-skel",
  "displayName": "Skel",
  "description": "Syntax highlighting and language-server support for .skel files.",
  "version": "0.0.0",
  "icon": "assets/icon.png",
  "publisher": "yorun",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yorun-ai/skel-editor-support.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/yorun-ai/skel-editor-support#visual-studio-code",
  "bugs": {
    "url": "https://github.com/yorun-ai/skel-editor-support/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "skel",
    "contract",
    "language server",
    "rpc",
    "vine"
  ],
  "galleryBanner": {
    "color": "#242424",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": false,
      "description": "Skel language features require a workspace filesystem and the skelc executable."
    },
    "untrustedWorkspaces": {
      "supported": false,
      "description": "The extension starts the configured skelc executable."
    }
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:skel"
  ],
  "contributes": {
    "languages": [
      {
        "id": "skel",
        "aliases": [
          "Skel",
          "skel"
        ],
        "extensions": [
          ".skel"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "skel",
        "scopeName": "source.skel",
        "path": "./syntaxes/skel.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Skel Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/skel-dark-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "skel.restartLanguageServer",
        "title": "Restart Language Server",
        "category": "Skel"
      },
      {
        "command": "skel.showLanguageServerOutput",
        "title": "Show Language Server Output",
        "category": "Skel"
      }
    ],
    "configuration": {
      "title": "Skel",
      "properties": {
        "skelc.path": {
          "type": "string",
          "default": "skelc",
          "scope": "machine-overridable",
          "description": "Path to the skelc v0.9.4 or newer executable used for the Skel language server. Changes restart the server automatically."
        },
        "skelc.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "scope": "window",
          "description": "Trace communication between VS Code and the Skel language server."
        }
      }
    }
  },
  "scripts": {
    "build": "node ../../scripts/prepare-assets.js && esbuild ./src/extension.js --bundle --platform=node --external:vscode --sourcemap --outfile=./out/extension.js",
    "check": "npm run build && npm run test:unit && node ./scripts/check.js",
    "check:release": "node ./scripts/check-release.js",
    "package:vsix": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish",
    "verify:marketplace": "vsce verify-pat yorun",
    "test:unit": "node --test ./test/unit/*.test.js",
    "test:integration": "node --test ./test/lsp.integration.test.js",
    "test:extension": "node ./test/run-extension-tests.js",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  },
  "devDependencies": {
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "^0.28.1"
  }
}
